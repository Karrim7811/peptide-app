# =============================================================
# Peptide Cortex — environment variables
# Copy to .env.local for development. Set on Vercel for production.
# Every variable is required unless explicitly noted.
# =============================================================

# Supabase (used by client + server + API routes)
#   NEXT_PUBLIC_* values are exposed to the browser; the anon key is fine
#   on the client because all access is RLS-gated.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic Claude (used by all /api/* AI endpoints — server-only)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe — payments (use live keys in production only)
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is exposed to the browser.
#   STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are server-only.
#   The price IDs come from Stripe Dashboard -> Products.
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Prices — see CLAUDE.md S16.4 / S16.5 for the locked pricing
#   STRIPE_PRO_MONTHLY_PRICE_ID  -> recurring $9.99/mo Pro subscription
#   STRIPE_PRO_LIFETIME_PRICE_ID -> one-time $99.99 Lifetime Pro purchase
#   (The deprecated yearly SKU has been removed.)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_LIFETIME_PRICE_ID=price_...
